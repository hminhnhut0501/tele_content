PORT=8000
DATABASE_MODE=sqlite
TELEVAULT_DB_PATH=/tmp/content_hub.db

# Set this on Render/Supabase to switch the app to Postgres mode automatically.
DATABASE_URL=

# Telegram app credentials
TG_API_ID=123456
TG_API_HASH=your_api_hash

# Recommended for Render free
TG_STRING_SESSION=your_string_session

# Fallback only if you really keep a local session file.
TG_SESSION_PATH=sessions/filter
